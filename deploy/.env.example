# Exemplo das variáveis usadas no deploy (EC2 + docker-compose).
# Copie para deploy/.env na instância e preencha. NUNCA comite o .env real.

# --- Banco (consumido pelo serviço db, migrate e app) ---
MYSQL_ROOT_PASSWORD=troque-esta-senha
MYSQL_DATABASE=flightviz
# Host "db" = nome do serviço MySQL no docker-compose
DATABASE_URL=mysql://root:troque-esta-senha@db:3306/flightviz

# --- Sessão ---
JWT_SECRET=gere-um-segredo-aleatorio-longo

# --- Login de desenvolvimento em produção (temporário) ---
# Permite acessar o app sem o OAuth da Manus (que não funciona fora da plataforma).
# IMPORTANTE: em produção, DEV_LOGIN_SECRET é OBRIGATÓRIO. Se ALLOW_DEV_LOGIN=true
# e o segredo não for definido, a rota /api/dev-login é desabilitada (fail-closed).
# Gere um valor único e forte (ex.: openssl rand -hex 24) — NÃO use este placeholder.
ALLOW_DEV_LOGIN=true
DEV_LOGIN_SECRET=gere-outro-segredo-aleatorio

# --- Login com Google OAuth (login real do app) ---
# Crie em https://console.cloud.google.com → APIs & Services → Credentials → OAuth client ID (Web).
# Redirect URI autorizado: https://djiflaylog.app/api/auth/google/callback
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
# E-mails que entram como admin (separados por vírgula)
ADMIN_EMAILS=felips2ribeiro@gmail.com,isaias.oceano@gmail.com

# --- OAuth Manus (não usado fora da plataforma; mantido por compatibilidade) ---
VITE_APP_ID=flight-visualizer-pro
OAUTH_SERVER_URL=https://example.invalid
VITE_OAUTH_PORTAL_URL=https://example.invalid

# --- Parser DJI Fly TXT (opcional) ---
DJI_API_KEY=
